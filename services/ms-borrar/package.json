    "express": "^4.21.2",
    "helmet": "^8.2.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.28.0",
    "@types/express": "^5.0.1",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.1.0",
    "testcontainers": "^10.28.0"
  }
