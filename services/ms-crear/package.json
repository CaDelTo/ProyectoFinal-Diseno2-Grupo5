{
  "name": "ms-crear",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "test:cov": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@shared/db": "workspace:*",
    "@shared/errors": "workspace:*",
    "@shared/health": "workspace:*",
    "@shared/logger": "workspace:*",
    "@shared/validators": "workspace:*",
    "express": "^4.21.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0"
  }
}
