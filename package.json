{
  "name": "sistema-gestion-datos-personales",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de Gestión de Datos Personales — Trabajo Final Diseño de Software II 2026",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "prisma generate --schema=db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=db/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --force --schema=db/prisma/schema.prisma",
    "compose:up": "docker compose up --build",
    "compose:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@jest/globals": "^30.4.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
