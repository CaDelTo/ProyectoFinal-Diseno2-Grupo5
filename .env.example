# ============================================================================
# Variables de entorno — plantilla
# ============================================================================
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA commitees `.env` con secretos.
# Catálogo completo: ver spec 000-arquitectura §4.5

# ---------- Base de datos (PostgreSQL + pgvector) ----------
DATABASE_URL=postgresql://app:app@db:5432/datos
DATABASE_URL_READONLY=postgresql://reader:reader@db:5432/datos
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=datos
READER_PASSWORD=reader

# ---------- SSO Microsoft Entra ID (ADR 0004) ----------
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-me
AZURE_REDIRECT_URI=http://localhost/api/v1/auth/callback
FRONTEND_URL=http://localhost:3000

# ---------- ms-log — token interno para escritura de auditoría (spec 008) ----------
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_TOKEN=replace-me-with-random-64-hex-chars

# ---------- Almacenamiento de fotos (MinIO — ADR 0009) ----------
STORAGE_ENDPOINT=http://storage:9000
STORAGE_BUCKET=personas-fotos
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------- ms-consultar — URL de ms-log para logs de auditoría QUERY (spec 005) ----------
MS_LOG_URL=http://ms-log:4005

# ---------- Logging (ADR 0011) ----------
LOG_LEVEL=debug
NODE_ENV=development

# ---------- Rate limiting (Gateway) ----------
RATE_LIMIT_MUT=60
RATE_LIMIT_READ=200

# ---------- n8n / RAG (ADR 0003) ----------
N8N_HOST=localhost
N8N_PORT=5678
N8N_OPENAI_KEY=sk-replace-if-using-openai
N8N_LOG_WEBHOOK=http://api-gateway/api/v1/logs/internal
EMBEDDING_PROVIDER=openai
# EMBEDDING_PROVIDER=ollama
# OLLAMA_HOST=http://ollama:11434
